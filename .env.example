# Steem Auto-Voter Configuration

# Your Steem username (without @)
STEEM_USERNAME=yourusername

# Your posting private key (WIF format, starts with 5...)
STEEM_POSTING_KEY=5Jxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Authors to auto-vote (comma-separated, without @)
VOTE_AUTHORS=author1,author2,author3

# Vote weight: 10000 = 100%, 5000 = 50%, 1000 = 10%
VOTE_WEIGHT=10000

# Steem API nodes (comma-separated for failover, auto-switches on failure)
STEEM_API_URL=https://api.steemit.com,https://api.justyy.com,https://steem-api.wan.io,https://anyx.io

# Delay between votes in milliseconds (to avoid rate limits)
VOTE_DELAY_MS=5000

# Scan interval in minutes
SCAN_INTERVAL_MINUTES=20

# ==================== Hive Auto-Vote ====================

# Hive username
HIVE_ACCOUNT=yourusername

# Hive posting private key (WIF format)
HIVE_POSTING_KEY=5Jxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hive API nodes (comma-separated for failover, auto-switches on failure)
HIVE_API_URL=https://api.hive.blog,https://api.openhive.network,https://hive-api.arcange.eu,https://rpc.ausbit.dev,https://api.deathwing.me

# Auto-vote following list: username:weight, separated by comma
# weight: 100 = 100%, 50 = 50%
HIVE_FOLLOWING=user1:100,user2:50,user3:30

# Vote interval in minutes (15 = 15 minutes)
HIVE_VOTE_INTERVAL=15

# Timezone for log timestamps (e.g. Asia/Shanghai, Asia/Tokyo, UTC)
TIMEZONE=Asia/Shanghai

# Log file path (default: steemit_vote.log in current directory)
STEEMIT_LOG_FILE=steemit_vote.log

# Hive log file path (default: hive_vote.log in current directory)
HIVE_LOG_FILE=hive_vote.log
