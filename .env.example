# Steem Auto-Voter Configuration

# Your Steem username (without @)
STEEM_USERNAME=yourusername

# Your posting private key (WIF format, starts with 5...)
# Find it in: steemit.com → Wallet → Permissions → Show Private Key (Posting)
STEEM_POSTING_KEY=5Jxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Authors to auto-vote (comma-separated, without @)
VOTE_AUTHORS=author1,author2,author3

# Vote weight: 10000 = 100%, 5000 = 50%, 1000 = 10%
VOTE_WEIGHT=10000

# Steem API node (change if default is slow)
STEEM_API_URL=https://api.steemit.com

# Delay between votes in milliseconds (to avoid rate limits)
VOTE_DELAY_MS=5000

# Scan interval in minutes
SCAN_INTERVAL_MINUTES=20
